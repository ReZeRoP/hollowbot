# ==========================================================================
#  VPN Sales Bot — environment configuration
#  Copy this file to `.env` and fill in real values. NEVER commit `.env`.
# ==========================================================================

# --- Telegram ---
BOT_TOKEN=123456:ABC-DEF_your_bot_token_here
# Comma-separated numeric Telegram IDs with SUPER admin rights.
SUPER_ADMIN_IDS=111111111,222222222
# Group/chat where receipts are posted for approval (numeric id, usually negative).
ADMIN_GROUP_ID=-1001234567890
# Channel(s) users must join before using the bot (comma-separated @usernames or ids).
FORCE_JOIN_CHANNELS=@my_channel

# --- Database ---
# SQLite (default, zero-setup):
DATABASE_URL=sqlite+aiosqlite:///./data/bot.db
# PostgreSQL (production) — uncomment and adjust:
# DATABASE_URL=postgresql+asyncpg://vpnbot:vpnbot@db:5432/vpnbot

# --- Locale / currency ---
CURRENCY=تومان
LOCALE=fa
TIMEZONE=Asia/Tehran

# --- Free monthly config (defaults; also editable at runtime in admin settings) ---
FREE_QUOTA_GB=5
FREE_PERIOD_DAYS=30

# --- Referral rewards (defaults; editable at runtime) ---
REFERRAL_BONUS_GB=1            # GB granted to inviter per successful invite
REFERRAL_TOPUP_PERCENT=10      # % of invitee top-ups paid to inviter (by the system)

# --- Payments (card-to-card) ---
CARD_NUMBER=6037-9999-9999-9999
CARD_HOLDER=Ali Rezaei

# --- Feature flags ---
SALES_ENABLED=true

# --- Backups ---
BACKUP_DIR=./backups
BACKUP_KEEP_DAYS=14

# --- Logging ---
LOG_LEVEL=INFO
